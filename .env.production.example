# Production-like deployment template.
# Copy to a private .env.production file or inject these values through a
# deployment secret manager. Never commit real values.

APP_NAME=CareerAgent API
APP_ENV=production
BACKEND_CORS_ORIGINS=https://careeragent.example.com

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
AUTH_JWT_SECRET=<managed-secret-at-least-32-random-characters>
AUTH_TOKEN_EXPIRE_MINUTES=60
API_RATE_LIMIT_PER_MINUTE=120

DATA_ENCRYPTION_KEY=<managed-fernet-key-from-secret-manager>
DATA_ENCRYPTION_KEY_ID=prod-2026-07-v1

POSTGRES_USER=careeragent
POSTGRES_PASSWORD=<managed-postgres-password>
POSTGRES_DB=careeragent
DATABASE_URL=postgresql+psycopg://careeragent:<managed-postgres-password>@postgres:5432/careeragent
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_ECHO_SQL=false
LOCAL_DATA_DIR=/app/backend/local_data

AI_PROVIDER_MODE=deterministic
LLM_PROVIDER=deterministic
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.0

EMBEDDING_PROVIDER=local
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=local-bow-v1
EMBEDDING_DIMENSION=384
EMBEDDING_PROVIDER_CONFIG_ID=prod-embedding-provider-v1

# v3.2 supports optional semantic provider, reranker, and LLM grounded answer
# paths. Keep defaults offline until real providers and benchmarks are verified.
VECTOR_STORE=local
RAG_RETRIEVAL_MODE=lexical
RAG_RERANKER_MODE=none
RAG_RERANKER_MODEL=local-score-v1
RAG_ANSWER_MODE=deterministic_summary
ENABLE_REAL_LLM=false
ENABLE_REAL_EMBEDDING=false

VITE_API_BASE_URL=/api
