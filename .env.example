# Application
APP_NAME=CareerAgent API
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Dev-only placeholder. Production must override this with a strong random secret.
AUTH_JWT_SECRET=dev-only-change-me-careeragent-local-auth-secret-32chars
AUTH_TOKEN_EXPIRE_MINUTES=60
API_RATE_LIMIT_PER_MINUTE=0

# Dev-only Fernet key for local encryption-at-rest. Production must override
# with a managed secret and rotate by changing DATA_ENCRYPTION_KEY_ID.
DATA_ENCRYPTION_KEY=MKlKIfl6Htn3qasq6OmUZrAptCgKZk_unRl07h5u6Ew=
DATA_ENCRYPTION_KEY_ID=local-dev-v1

# Database. Do not store real credentials here. SQLite is local/dev only.
# When running the backend from ./backend, this creates ./backend/local_data/careeragent.db.
DATABASE_URL=sqlite:///./local_data/careeragent.db
# Production target example. Use deployment secrets, not this placeholder.
# APP_ENV=production rejects SQLite and placeholder secrets.
# DATABASE_URL=postgresql+psycopg://careeragent:CHANGE_ME_STRONG_PASSWORD@postgres:5432/careeragent
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_ECHO_SQL=false
LOCAL_DATA_DIR=local_data

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Observability. Leave DSNs empty locally. Do not commit real DSNs or tokens.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false
ENABLE_OBSERVABILITY_TEST_ENDPOINT=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACE_TARGETS=http://localhost:8000
VITE_ENABLE_OBSERVABILITY_TEST_TOOLS=false

# Production AI readiness. Defaults are local and deterministic.
AI_PROVIDER_MODE=deterministic
LLM_PROVIDER=deterministic
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.0

EMBEDDING_PROVIDER=local
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=local-bow-v1
EMBEDDING_DIMENSION=384
EMBEDDING_PROVIDER_CONFIG_ID=local-bow-default

VECTOR_STORE=local
RAG_RETRIEVAL_MODE=lexical
RAG_RERANKER_MODE=none
RAG_RERANKER_MODEL=local-score-v1
RAG_ANSWER_MODE=deterministic_summary
ENABLE_REAL_LLM=false
ENABLE_REAL_EMBEDDING=false

# Backward-compatible empty placeholders. Do not commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=
