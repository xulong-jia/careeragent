# Application
APP_NAME=CareerAgent API
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database. Do not store real credentials here.
# When running the backend from ./backend, this creates ./backend/local_data/careeragent.db.
DATABASE_URL=sqlite:///./local_data/careeragent.db

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# LLM placeholders for later phases. Current deterministic MVP does not require them.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=
