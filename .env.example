# Application
APP_NAME=CareerAgent API
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database. Do not store real credentials here.
# When running the backend from ./backend, this creates ./backend/local_data/careeragent.db.
DATABASE_URL=sqlite:///./local_data/careeragent.db

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Production AI readiness. Defaults are local and deterministic.
AI_PROVIDER_MODE=deterministic
LLM_PROVIDER=deterministic
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.0

EMBEDDING_PROVIDER=deterministic
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=deterministic-hash-v1
EMBEDDING_DIMENSION=384

VECTOR_STORE=local
RAG_RETRIEVAL_MODE=lexical
ENABLE_REAL_LLM=false
ENABLE_REAL_EMBEDDING=false

# Backward-compatible empty placeholders. Do not commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=
