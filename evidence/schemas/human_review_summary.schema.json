{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent Human Review Summary",
  "type": "object",
  "required": [
    "summary_type",
    "source_review_batch_id",
    "total_items",
    "pass_count",
    "fail_count",
    "minor_issue_count",
    "major_issue_count",
    "pass_rate",
    "average_correctness_score",
    "average_groundedness_score",
    "average_safety_score",
    "hallucination_rate",
    "fabrication_rate",
    "privacy_risk_count",
    "adjudication_completion_rate",
    "production_quality_candidate_signal"
  ],
  "properties": {
    "summary_type": { "const": "human_review_summary" },
    "source_review_batch_id": { "type": "string", "minLength": 1 },
    "dataset_name": { "type": "string" },
    "total_items": { "type": "integer", "minimum": 0 },
    "pass_count": { "type": "integer", "minimum": 0 },
    "fail_count": { "type": "integer", "minimum": 0 },
    "minor_issue_count": { "type": "integer", "minimum": 0 },
    "major_issue_count": { "type": "integer", "minimum": 0 },
    "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "average_correctness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "average_groundedness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "average_safety_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "hallucination_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "fabrication_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "privacy_risk_count": { "type": "integer", "minimum": 0 },
    "adjudication_completion_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "production_quality_candidate_signal": { "type": "boolean" },
    "threshold_failures": { "type": "array", "items": { "type": "string" } },
    "thresholds": { "type": "object" }
  }
}
