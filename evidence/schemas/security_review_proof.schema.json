{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent External Security Review Proof",
  "type": "object",
  "required": [
    "proof_type",
    "proof_id",
    "created_at",
    "reviewer_redacted",
    "scope",
    "critical_findings_open",
    "high_findings_open",
    "privacy_review_passed",
    "remediation_plan_attached",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "security_review" },
    "proof_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "reviewer_redacted": { "type": "string" },
    "scope": { "type": "array", "items": { "type": "string" } },
    "critical_findings_open": { "type": "integer", "minimum": 0 },
    "high_findings_open": { "type": "integer", "minimum": 0 },
    "privacy_review_passed": { "type": "boolean" },
    "remediation_plan_attached": { "type": "boolean" },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
