{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent External Security Review Proof",
  "type": "object",
  "required": [
    "proof_type",
    "proof_id",
    "created_at",
    "reviewer",
    "review_scope",
    "auth_session_review_passed",
    "privacy_review_passed",
    "dependency_scan_passed",
    "secret_scan_passed",
    "pii_redaction_review_passed",
    "rate_limit_review_passed",
    "vulnerability_findings",
    "critical_findings_count",
    "high_findings_count",
    "unresolved_findings_count",
    "production_quality_candidate_signal",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "security_review" },
    "proof_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "review_scope": { "type": "array", "items": { "type": "string" } },
    "auth_session_review_passed": { "type": "boolean" },
    "privacy_review_passed": { "type": "boolean" },
    "dependency_scan_passed": { "type": "boolean" },
    "secret_scan_passed": { "type": "boolean" },
    "pii_redaction_review_passed": { "type": "boolean" },
    "rate_limit_review_passed": { "type": "boolean" },
    "vulnerability_findings": { "type": "array", "items": { "type": "string" } },
    "critical_findings_count": { "type": "integer", "minimum": 0 },
    "high_findings_count": { "type": "integer", "minimum": 0 },
    "unresolved_findings_count": { "type": "integer", "minimum": 0 },
    "production_quality_candidate_signal": { "type": "boolean" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "template_only": { "type": "boolean" }
  }
}
