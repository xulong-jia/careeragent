{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent Monitoring Proof",
  "type": "object",
  "required": [
    "proof_type",
    "proof_id",
    "created_at",
    "metrics_backend",
    "log_drain",
    "tracing_backend",
    "error_reporting",
    "alert_rules_verified",
    "privacy_redaction_verified",
    "incident_runbook_verified",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "monitoring" },
    "proof_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "metrics_backend": { "type": "string" },
    "log_drain": { "type": "string" },
    "tracing_backend": { "type": "string" },
    "error_reporting": { "type": "string" },
    "alert_rules_verified": { "type": "boolean" },
    "privacy_redaction_verified": { "type": "boolean" },
    "incident_runbook_verified": { "type": "boolean" },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
