{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent Backup Purge Proof",
  "type": "object",
  "required": [
    "proof_type",
    "proof_id",
    "created_at",
    "deletion_proof_id",
    "affected_backup_ids_redacted",
    "backup_purge_status",
    "legal_hold_status",
    "restore_block_rule_verified",
    "audit_artifact_redacted",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "backup_purge" },
    "proof_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "deletion_proof_id": { "type": "string", "minLength": 1 },
    "affected_backup_ids_redacted": { "type": "array", "items": { "type": "string" } },
    "backup_purge_status": { "enum": ["complete", "pending_retention_expiry", "legal_hold", "not_implemented"] },
    "legal_hold_status": { "type": "string" },
    "restore_block_rule_verified": { "type": "boolean" },
    "audit_artifact_redacted": { "type": "string" },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
