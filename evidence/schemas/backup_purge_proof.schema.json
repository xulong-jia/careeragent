{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent Backup Purge Proof",
  "type": "object",
  "required": [
    "proof_type",
    "proof_id",
    "created_at",
    "database_backup_verified",
    "restore_test_passed",
    "delete_all_test_passed",
    "backup_purge_verified",
    "legal_hold_behavior_verified",
    "restore_after_delete_blocked_or_redacted",
    "retention_policy_documented",
    "evidence_refs",
    "production_quality_candidate_signal",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "backup_purge" },
    "proof_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "database_backup_verified": { "type": "boolean" },
    "restore_test_passed": { "type": "boolean" },
    "delete_all_test_passed": { "type": "boolean" },
    "backup_purge_verified": { "type": "boolean" },
    "legal_hold_behavior_verified": { "type": "boolean" },
    "restore_after_delete_blocked_or_redacted": { "type": "boolean" },
    "retention_policy_documented": { "type": "boolean" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "production_quality_candidate_signal": { "type": "boolean" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "template_only": { "type": "boolean" }
  }
}
