{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent External Human Review Batch",
  "type": "object",
  "required": [
    "proof_type",
    "review_batch_id",
    "created_at",
    "reviewer_count",
    "reviewer_roles",
    "dataset_name",
    "sample_size",
    "sampling_method",
    "privacy_sanitized",
    "review_items",
    "agreement_metrics",
    "adjudication_required_count",
    "adjudication_completed_count",
    "bad_case_count",
    "production_quality_candidate_signal",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "human_review" },
    "review_batch_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "reviewer_count": { "type": "integer", "minimum": 0 },
    "reviewer_roles": { "type": "array", "items": { "type": "string" } },
    "dataset_name": { "type": "string", "minLength": 1 },
    "sample_size": { "type": "integer", "minimum": 0 },
    "sampling_method": { "type": "string", "minLength": 1 },
    "privacy_sanitized": { "type": "boolean" },
    "review_items": {
      "type": "array",
      "items": { "$ref": "human_review_item.schema.json" }
    },
    "agreement_metrics": { "type": "object" },
    "adjudication_required_count": { "type": "integer", "minimum": 0 },
    "adjudication_completed_count": { "type": "integer", "minimum": 0 },
    "bad_case_count": { "type": "integer", "minimum": 0 },
    "summary": { "type": "object" },
    "production_quality_candidate_signal": { "type": "boolean" },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
