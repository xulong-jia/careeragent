{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CareerAgent External Deployment Proof",
  "type": "object",
  "required": [
    "proof_type",
    "proof_id",
    "created_at",
    "environment",
    "deployment_provider",
    "app_url_redacted",
    "backend_health_passed",
    "readiness_passed",
    "migration_status",
    "managed_database",
    "secret_manager_used",
    "kms_or_encryption_key_used",
    "tls_enabled",
    "rollback_plan_verified",
    "smoke_tests_passed",
    "evidence_refs",
    "production_quality_candidate_signal",
    "limitations"
  ],
  "properties": {
    "proof_type": { "const": "deployment" },
    "proof_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "environment": { "type": "string", "minLength": 1 },
    "deployment_provider": { "type": "string", "minLength": 1 },
    "app_url_redacted": { "type": "string", "minLength": 1 },
    "backend_health_passed": { "type": "boolean" },
    "readiness_passed": { "type": "boolean" },
    "migration_status": {
      "enum": ["applied", "up_to_date", "completed", "failed", "not_run"]
    },
    "managed_database": { "type": "boolean" },
    "secret_manager_used": { "type": "boolean" },
    "kms_or_encryption_key_used": { "type": "boolean" },
    "tls_enabled": { "type": "boolean" },
    "rollback_plan_verified": { "type": "boolean" },
    "smoke_tests_passed": { "type": "boolean" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "production_quality_candidate_signal": { "type": "boolean" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "template_only": { "type": "boolean" }
  }
}
